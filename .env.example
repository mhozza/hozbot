# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
ALLOWED_USER_IDS=123456789,987654321
# User IDs to receive startup/shutdown messages (comma-separated, empty = disabled)
SEND_HI_BYE=123456789

# Gemini Configuration
GOOGLE_API_KEY=your_gemini_api_key_here

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Email IMAP Configuration
EMAIL_IMAP_SERVER=imap.gmail.com
EMAIL_ADDRESS=your_email@gmail.com
EMAIL_APP_PASSWORD=your_app_password_here

# Bin Collection (St Albans)
# Use tools/get_uprn.py to resolve your address to a UPRN.
BIN_UPRN=100000000000

# Scheduled Job Configuration
EMAIL_CHECK_INTERVAL_MINUTES=15
EMAIL_CHECK_ENABLED=true
DIGEST_TIME=19:00
DIGEST_ENABLED=true
SEND_DIGEST_ON_START=false
